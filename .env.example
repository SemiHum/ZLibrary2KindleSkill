# ZLibrary credentials
ZLIBRARY_EMAIL=your@email.com
ZLIBRARY_PASSWORD=your_password

# Kindle
KINDLE_EMAIL=your_kindle@kindle.com

# SMTP sender
SENDER_EMAIL=your@email.com
SENDER_PASSWORD=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Session persistence
ZLIBRARY_SESSION_PATH=~/.cache/zlibrary2kindle/session.json
